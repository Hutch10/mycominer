# MycoMiner Environment Variables

# Agent Runtime Configuration
# URL where the agent runtime service is deployed
AGENT_RUNTIME_URL=http://localhost:8080

# Application Environment
# Set to 'production' for deployments
NODE_ENV=development

# Next.js Configuration
# Enable React strict mode for catching bugs
NEXT_PUBLIC_REACT_STRICT_MODE=true

# Supabase (persistent storage for workflows, marketplace, billing)
# Tables live in the `mycominer` schema on project dcbjjvygjhmngwzuwdjj until a dedicated project is available.
# Get keys from: https://supabase.com/dashboard/project/dcbjjvygjhmngwzuwdjj/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://dcbjjvygjhmngwzuwdjj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Development-only auth headers for persistence APIs (never enable in production)
# Requires: X-MycoMiner-User-Id and X-MycoMiner-Org-Id
MYCOMINER_DEV_AUTH_HEADERS=0

# Stripe (server-only — omit for stub/test mode; no live charges without sk_test_/sk_live_)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Distributed rate limiting (required in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Deployment fingerprint (set at build/deploy; server-only — not NEXT_PUBLIC_)
MYCOMINER_GIT_COMMIT=
MYCOMINER_BUILD_TIMESTAMP=
MYCOMINER_MIGRATION_VERSION=008
MYCOMINER_ARCHITECTURE_VERSION=1.0
MYCOMINER_RELEASE_CHANNEL=closed-beta

# Optional: Analytics and Monitoring
# Uncomment and configure if using analytics service
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id

# Optional: Logging Level
# Set to 'debug', 'info', 'warn', or 'error'
LOG_LEVEL=info
